---
layout: layouts/base.njk
permalink: /
---

<section class="hero">
  <div class="hero-badge">{{ homepage.hero.badge }}</div>
  <h1>{{ homepage.hero.headlineBefore }}<br><em><span class="highlight">{{ homepage.hero.headlineHighlight }}</span></em></h1>
  <p>{{ homepage.hero.description }}</p>
  <a href="{{ site.chromeStoreUrl }}" class="hero-cta" style="margin-bottom: 2rem;">
    <span class="hero-cta-icon" aria-hidden="true">{{ "hamsa-white.svg" | inlineSvg | safe }}</span>
    {{ homepage.hero.cta }}
  </a>
</section>

<section class="problem">
  <div class="problem-inner">
    {% for paragraph in homepage.problem.paragraphs %}
    <p>{{ paragraph | safe }}</p>
    {% endfor %}
  </div>
</section>

<section class="section">
  <h2>{{ homepage.steps.title }}</h2>
  <div class="steps">
    {% for step in homepage.steps.items %}
    <div class="step">
      <div class="step-num">{{ step.number }}</div>
      <h3>{{ step.title }}</h3>
      <p>{{ step.description }}</p>
    </div>
    {% endfor %}
  </div>
  <p style="text-align:center; margin-top:2rem; font-size:1.1rem; color:var(--text-hint);">{{ homepage.steps.footnote }}</p>
</section>

<section class="features-bg">
  <div class="features-inner">
    <h2 style="text-align:center; font-family:'Lora',serif; font-size:clamp(1.6rem,3.5vw,2.2rem); font-weight:600; color:var(--blue-dark); margin-bottom:0.75rem;">
      {{ homepage.features.title }}</h2>
    <div class="features-intro" style="margin-bottom:2.5rem;">
      <p>{{ homepage.features.intro }}</p>
    </div>
    {% include "partials/feature-grid.njk" %}
  </div>
</section>

<section class="cta-section" id="install">
  <h2>{{ homepage.cta.titleBefore }} <span class="highlight">{{ homepage.cta.titleHighlight }}</span>{{ homepage.cta.titleAfter }}</h2>
  <p>{{ homepage.cta.description }}</p>
  <a href="{{ site.chromeStoreUrl }}" class="hero-cta">
    <span class="hero-cta-icon" aria-hidden="true">{{ "hamsa-white.svg" | inlineSvg | safe }}</span>
    {{ homepage.cta.button }}
  </a>
</section>
